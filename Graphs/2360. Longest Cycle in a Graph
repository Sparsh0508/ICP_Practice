In this questiuon we have to find the longest cycle form in the given directed graph.
1) first we assign all value of edge with there indes ton arraylist so we can traverse on that
2) then we made two different array(visitedd) so that we can make a record on what we traverse 
3)Now we traverse in that using dfs and check all len and compare with prev len.
4)In dfs function, first we mark on visit array that here we traverse so that we cannot take it twice.
5)now traverse on all neighbour of that node and check the cycle.
6)everytime we update dist array and store all value
7) at last we reassign the value of dist to -1;
8) And return maxlen;




class Solution {
    public int longestCycle(int[] edges) {
        int n = edges.length;
        ArrayList<ArrayList<Integer>> al = new ArrayList<>();
        for(int i = 0;i<n;i++){
            al.add(new ArrayList<>());
        }
        for(int i = 0;i<n;i++){
            int u = i;
            int v = edges[i];
            if(v != -1){
                al.get(u).add(v);
            }
        }
        int max = -1;
        boolean[] vis = new boolean[n];
        int[] dist = new int[n];
        Arrays.fill(dist,-1);
        for(int i = 0;i<n;i++){
            if(!vis[i]){
                dist[i] = 0;
                max = Math.max(max,dfs(al,vis,i,dist));
            }
        }
        return max ;
    }
    public static int dfs(ArrayList<ArrayList<Integer>> edge,boolean[] vis,int node,int[] dist){
        vis[node] = true;
        int len = -1;
        for(int nei : edge.get(node)){
            if(!vis[nei]){
                dist[nei] = dist[node] + 1;
                len = Math.max(len,dfs(edge,vis,nei,dist));
            }
            else if(dist[nei] != -1){
                len = Math.max(len,dist[node] - dist[nei] +1);
            }
        }
        dist[node] = -1;
        return len;

    }
}
